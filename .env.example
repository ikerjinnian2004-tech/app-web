# Copia este archivo como .env y cambia las claves antes de usar la aplicacion.
DATABASE_URL=sqlite:///./dev.db
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-minimo-32-chars
IDENTITY_HMAC_KEY=cambia-esto-por-una-clave-hmac-aleatoria-minimo-32-chars

EXAM_DURATION_MINUTES=90
SANDBOX_TIMEOUT_SECONDS=3
SANDBOX_MAX_OUTPUT_CHARS=5000
SANDBOX_USE_DOCKER=false
SANDBOX_IMAGE=evaluador-sandbox:local
SANDBOX_MEM_LIMIT_MB=64
SANDBOX_CPU=0.5
SANDBOX_PIDS_LIMIT=50

EVIDENCIA_MAX_BYTES=15000000
EVIDENCIA_DURACION_SEGUNDOS=15

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
LOG_LEVEL=INFO
HEALTHCHECK_INTERVAL_SECONDS=30
